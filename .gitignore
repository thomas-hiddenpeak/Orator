# Build output
/build*/
*.o
*.a
*.so

# CUDA / profiling artifacts
*.nsys-rep
*.sqlite

# Model weights & reference activations (large binaries, regenerated by tools)
models/

# Vendored / downloaded third-party sources & libs
third_party/
tools/extralibs/

# Python environment (uv-managed wheels: torch etc.)
tools/.venv/
tools/venv/
__pycache__/
*.pyc
.pytest_cache/

# Test audio (large media) + private reference transcript (CER gold)
test.mp3
test.txt
asrTest2Final.txt
*.pcm
test_audio.pcm

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

# One-off experiment scripts (not version-controlled)
tools/tmp_*

# AI session runtime files
.omo/

# Local Codex/runtime configuration and cache. May contain secrets.
config/

# CTest temporary files
Testing/

# Runtime log files
*.log
orator_ws.log

# Local runtime/session output. Canonical acceptance artifacts live outside the
# repository and are referenced by immutable hashes in the review records.
/storage/
/sessions/
/runtime/
/artifacts/
/test-results/
/playwright-report/
/screenshots/
/spec013-speakers.bin
/*-speakers.bin
